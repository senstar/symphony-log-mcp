{
  "fixture": "connectivity-problems",
  "description": "Server 5003 goes down for ~40 minutes. Multiple SEEMS FAILED detections, connection refused, DNS resolution failure for NODE3.corp.local, RPC timeouts. Server eventually recovers (BACK UP). Two 'No message dispatcher' overload events after recovery.",
  "expectedIssues": [
    {
      "severity": "CRITICAL",
      "category": "Connectivity",
      "keyPhrases": ["SEEMS FAILED", "5003"]
    },
    {
      "severity": "WARNING",
      "category": "Connectivity",
      "keyPhrases": ["DNS", "NODE3.corp.local"]
    }
  ],
  "triage": {
    "expectedSeverity": "CRITICAL",
    "mustContain": ["SEEMS FAILED", "5003", "CRITICAL", "BACK UP"],
    "mustNotContain": ["crash-loop"]
  },
  "errors": {
    "expectedCount": { "min": 5, "max": 20 },
    "expectedPatterns": ["Unable to connect", "Connection refused", "TimeoutException"]
  },
  "lifecycle": {
    "expectedRestarts": { "min": 0, "max": 1 },
    "expectedEvents": ["Service starting", "Service started"]
  },
  "health": {
    "expectedRating": "HEALTHY",
    "crashLoopProcesses": []
  },
  "connectivity": {
    "expectedIssueCount": 1,
    "mustContain": ["SEEMS FAILED", "5003"]
  }
}
